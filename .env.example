# Copy this file to .env and set your own Supabase project values.
# Do not commit your real keys.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional legacy / multi-project values if needed
VITE_SUPABASE_URL_1=https://legacy-project.supabase.co
VITE_SUPABASE_ANON_KEY_1=legacy-anon-key
VITE_SUPABASE_URL_2=https://json-project.supabase.co
VITE_SUPABASE_ANON_KEY_2=json-anon-key